# ============================================================
# Kinfolk — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required fields are marked [REQUIRED].
# Optional fields have sensible defaults.
# ============================================================

# ── Backend Server ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
DEBUG=false

# ── Database ─────────────────────────────────────────────────
# SQLite path (Docker overrides to /data/kinfolk.db)
DATABASE_URL=sqlite:///./kinfolk.db

# [REQUIRED] Encryption key for SQLCipher at-rest encryption.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
DATABASE_ENCRYPTION_KEY=replace_with_device_derived_secret

# ── Speech-to-Text (STT) ────────────────────────────────────
# Mode: "cloud" (Whisper API) or "local" (Vosk offline)
STT_MODE=local

# [REQUIRED if STT_MODE=cloud] OpenAI API key for Whisper
OPENAI_API_KEY=

# Path to Vosk model directory (local STT)
VOSK_MODEL_PATH=./models/vosk-model-en-us

# ── Text-to-Speech (TTS) ────────────────────────────────────
# Engine: "nanotts" (offline) or "gtts" (requires network)
TTS_ENGINE=nanotts
TTS_SPEED=1.0
TTS_VOLUME=0.8

# ── Wake Word Detection ─────────────────────────────────────
# Engine: "openwakeword" (recommended)
WAKE_WORD_ENGINE=openwakeword
# Sensitivity: 0.0 (least sensitive) to 1.0 (most sensitive)
WAKE_WORD_SENSITIVITY=0.5
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# ── Intent Recognition (NLU) ────────────────────────────────
# Minimum confidence to accept an intent (0.0–1.0)
NLU_CONFIDENCE_THRESHOLD=0.5
SENTENCES_INI_PATH=./backend/rhasspy/sentences.ini

# ── Google Calendar OAuth 2.0 ────────────────────────────────
# Create credentials at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/google/callback

# ── CalDAV Servers ───────────────────────────────────────────
# JSON array of CalDAV server configs. Example:
# CALDAV_SERVERS='[{"url":"https://nc.example.com/remote.php/dav/","username":"user","password":"pass","calendar_name":"personal"}]'
CALDAV_SERVERS=[]

# ── Weather (OpenWeatherMap) ─────────────────────────────────
# Get a free API key at https://openweathermap.org/api
OPENWEATHER_API_KEY=
WEATHER_CITY=San Francisco
WEATHER_UNITS=imperial

# ── Home Assistant ───────────────────────────────────────────
# URL of your Home Assistant instance
HA_URL=
# Long-lived access token from HA profile page
HA_TOKEN=

# ── Music (Mopidy) ──────────────────────────────────────────
# Mopidy JSON-RPC endpoint (Docker overrides to http://mopidy:6680/mopidy/rpc)
MOPIDY_URL=http://localhost:6680/mopidy/rpc

# ── Photo Frame ──────────────────────────────────────────────
# Directory containing photos for slideshow mode
PHOTOS_DIRECTORY=~/Pictures

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated allowed origins (Flutter dev server, etc.)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080,http://127.0.0.1:8080
CORS_ALLOW_ALL=false
